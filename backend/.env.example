# 选择 AI 提供商: claude | openai | gemini | bailian
AI_PROVIDER=claude

# Claude (Anthropic)
ANTHROPIC_API_KEY=
CLAUDE_VISION_MODEL=claude-opus-4-7
CLAUDE_TEXT_MODEL=claude-haiku-4-5-20251001

# OpenAI（可选；用于 Whisper / GPT-4o / Embeddings）
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_WHISPER_MODEL=whisper-1

# Gemini（可选）
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# 阿里云百炼 / DashScope（OpenAI 兼容模式，模型 ID 与维度全部可手填）
# Base URL 按地域换：
#   华北2（北京）        https://dashscope.aliyuncs.com/compatible-mode/v1
#   新加坡               https://dashscope-intl.aliyuncs.com/compatible-mode/v1
#   美国（弗吉尼亚）     https://dashscope-us.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_TEXT_MODEL=qwen-plus
DASHSCOPE_VISION_MODEL=qwen-vl-plus
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v3
# text-embedding-v3 默认 1024 维；v4 可在 1024/1536/2048 中选，切模型记得同步改维度并清库
DASHSCOPE_EMBEDDING_DIM=1024

# 嵌入与转写的 provider 单独配置，可以和主 provider 不同
# 取值：openai | gemini | bailian | claude | same
# - same：跟随 AI_PROVIDER；若主 provider 不支持该能力，会自动 fallback 到 openai
# - claude 没有原生 embedding 与 whisper
# - bailian 兼容模式没有 audio transcription（但有 embedding）
EMBEDDING_PROVIDER=openai
TRANSCRIBE_PROVIDER=openai

# 数据目录（相对 backend/ 或绝对路径）
DATA_DIR=./data

# 服务端口
HOST=127.0.0.1
PORT=8000

# 允许的前端来源（开发时 vite 默认 5173）
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
